{
  "name": "kmp-lsp-client",
  "publisher": "kmp-lsp",
  "displayName": "Kotlin LSP (kmp-lsp)",
  "description": "VSCode client for kmp-lsp",
  "version": "0.0.1",
  "icon": "icon.png",
  "engines": { "vscode": "^1.75.0" },
  "activationEvents": ["onLanguage:kotlin", "onLanguage:java", "onLanguage:swift"],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kotlin",
        "aliases": ["Kotlin"],
        "extensions": [".kt", ".kts"],
        "configuration": "./kotlin-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kotlin",
        "scopeName": "source.kotlin",
        "path": "./syntaxes/kotlin.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Kotlin LSP",
      "properties": {
        "kmpLsp.path": {
          "type": "string",
          "default": "kmp-lsp",
          "description": "Path to kmp-lsp binary"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
